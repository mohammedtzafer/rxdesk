generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Auth.js Models

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Enums

enum Role {
  OWNER
  PHARMACIST
  TECHNICIAN
}

enum Module {
  PROVIDERS
  PRESCRIPTIONS
  DRUG_REPS
  TIME_TRACKING
  TEAM
  REPORTS
  SETTINGS
}

enum Access {
  NONE
  VIEW
  EDIT
  FULL
}

enum Plan {
  STARTER
  GROWTH
  PRO
}

enum InviteStatus {
  PENDING
  ACCEPTED
  CANCELLED
}

enum UploadStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum PayerType {
  COMMERCIAL
  MEDICARE
  MEDICAID
  CASH
  OTHER
}

// Core Models

model Organization {
  id                   String   @id @default(cuid())
  name                 String
  timezone             String   @default("America/New_York")
  plan                 Plan     @default(STARTER)
  trialEndsAt          DateTime?
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  subscriptionEndsAt   DateTime?
  brandColor           String?
  logoUrl              String?
  brandName            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Time tracking settings
  payPeriodType             PayPeriodType @default(WEEKLY)
  payPeriodStartDay         Int           @default(1)
  dailyOvertimeThreshold    Float         @default(8)
  weeklyOvertimeThreshold   Float         @default(40)
  roundingRule              RoundingRule  @default(NONE)
  defaultBreakMinutes       Int           @default(30)
  defaultBreakType          BreakType     @default(UNPAID)
  autoDeductBreakThreshold  Float         @default(6)

  users       User[]
  locations   Location[]
  permissions Permission[]
  invites     Invite[]
  auditLogs   AuditLog[]

  providers             Provider[]
  prescriptionUploads   PrescriptionUpload[]
  prescriptionRecords   PrescriptionRecord[]
  drugReps              DrugRep[]
  drugRepVisits         DrugRepVisit[]

  departments           Department[]
  timeEntries           TimeEntry[]
  timesheets            Timesheet[]
  shiftAssignments      ShiftAssignment[]
  availabilityPrefs     AvailabilityPreference[]
  availabilityOverrides AvailabilityOverride[]
  ptoRequests           PtoRequest[]
  shiftSwapRequests     ShiftSwapRequest[]
  scheduleTemplates     ScheduleTemplate[]
  coverageRequirements  CoverageRequirement[]
  payRates              PayRate[]
  notifications         Notification[]
  weeklySchedules       WeeklySchedule[]
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  phone          String?
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           Role      @default(TECHNICIAN)
  active             Boolean   @default(true)
  organizationId     String?
  locationId         String?
  lastActiveAt       DateTime?
  targetHoursPerWeek Int       @default(40)
  sortOrder          Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  location     Location?     @relation(fields: [locationId], references: [id])
  accounts     Account[]
  sessions     Session[]
  permissions  Permission[]
  auditLogs    AuditLog[]
  invitesSent  Invite[]      @relation("InvitedBy")

  timeEntries   TimeEntry[]
  timesheets    Timesheet[]
  notifications Notification[]

  @@index([organizationId])
  @@index([locationId])
}

model Location {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  city           String?
  state          String?
  zip            String?
  phone          String?
  npiNumber      String?
  licenseNumber  String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  roles        Json         @default("[\"Pharmacist\", \"Technician\", \"Filling\", \"POS\", \"Driver\"]")

  organization    Organization     @relation(fields: [organizationId], references: [id])
  users           User[]
  weeklySchedules WeeklySchedule[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Permission {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  module         Module
  access         Access
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, module])
  @@index([userId])
  @@index([organizationId])
}

model Invite {
  id             String       @id @default(cuid())
  email          String
  role           Role         @default(TECHNICIAN)
  organizationId String
  invitedById    String
  locationId     String?
  token          String       @unique
  status         InviteStatus @default(PENDING)
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([organizationId])
  @@index([token])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entityType     String
  entityId       String
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([organizationId, entityType, entityId])
}

// ─── Prescription & Provider Models ─────────────────────────────

model Provider {
  id                String    @id @default(cuid())
  organizationId    String
  npi               String
  firstName         String
  lastName          String
  suffix            String?
  credential        String?
  specialty         String?
  practiceName      String?
  practiceAddress   String?
  practiceCity      String?
  practiceState     String?
  practiceZip       String?
  practicePhone     String?
  tags              Json      @default("[]")
  notes             String?
  isActive          Boolean   @default(true)
  enrichedFromNppes Boolean   @default(false)
  lastEnrichedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization          Organization           @relation(fields: [organizationId], references: [id])
  prescriptionRecords   PrescriptionRecord[]
  drugRepVisits         DrugRepVisitProvider[]

  @@unique([organizationId, npi])
  @@index([organizationId])
  @@index([organizationId, specialty])
}

model PrescriptionUpload {
  id             String       @id @default(cuid())
  organizationId String
  locationId     String?
  uploadedById   String
  fileName       String
  rowCount       Int          @default(0)
  dateRangeStart DateTime?
  dateRangeEnd   DateTime?
  status         UploadStatus @default(PROCESSING)
  errorMessage   String?
  createdAt      DateTime     @default(now())

  organization Organization         @relation(fields: [organizationId], references: [id])
  records      PrescriptionRecord[]
}

model PrescriptionRecord {
  id             String    @id @default(cuid())
  organizationId String
  locationId     String?
  uploadId       String
  providerId     String?
  providerNpi    String
  drugName       String
  drugNdc        String?
  isGeneric      Boolean   @default(false)
  fillDate       DateTime
  quantity       Int?
  daysSupply     Int?
  payerType      PayerType @default(OTHER)
  createdAt      DateTime  @default(now())

  organization Organization        @relation(fields: [organizationId], references: [id])
  upload       PrescriptionUpload  @relation(fields: [uploadId], references: [id])
  provider     Provider?           @relation(fields: [providerId], references: [id])

  @@index([organizationId, providerId, fillDate])
  @@index([organizationId, drugName, fillDate])
  @@index([organizationId, fillDate])
  @@index([organizationId, providerNpi])
}

// ─── Drug Rep Models ────────────────────────────────────────────

model DrugRep {
  id             String   @id @default(cuid())
  organizationId String
  firstName      String
  lastName       String
  company        String
  email          String?
  phone          String?
  territory      String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id])
  visits       DrugRepVisit[]

  @@index([organizationId])
  @@index([organizationId, company])
}

model DrugRepVisit {
  id              String   @id @default(cuid())
  organizationId  String
  locationId      String?
  drugRepId       String
  visitDate       DateTime
  durationMinutes Int?
  drugsPromoted   Json     @default("[]")
  samplesLeft     Json     @default("[]")
  notes           String?
  followUpDate    DateTime?
  loggedById      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id])
  drugRep      DrugRep               @relation(fields: [drugRepId], references: [id])
  providers    DrugRepVisitProvider[]

  @@index([organizationId, visitDate])
  @@index([organizationId, drugRepId])
}

model DrugRepVisitProvider {
  drugRepVisitId String
  providerId     String

  visit    DrugRepVisit @relation(fields: [drugRepVisitId], references: [id], onDelete: Cascade)
  provider Provider     @relation(fields: [providerId], references: [id])

  @@id([drugRepVisitId, providerId])
}

// ─── Time Tracking Enums ────────────────────────────────────────

enum TimesheetStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum PayPeriodType {
  WEEKLY
  BIWEEKLY
  SEMIMONTHLY
  MONTHLY
}

enum RoundingRule {
  NONE
  NEAREST_5
  NEAREST_15
  NEAREST_30
}

enum BreakType {
  PAID
  UNPAID
  AUTO_DEDUCT
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum PtoType {
  VACATION
  SICK
  PERSONAL
  OTHER
}

enum PtoStatus {
  PENDING
  APPROVED
  DENIED
}

enum ShiftSwapStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

enum AvailabilityState {
  ALL_DAY
  HOURS
  UNAVAILABLE
}

enum NotificationType {
  SCHEDULE_PUBLISHED
  SCHEDULE_UPDATED
  PTO_SUBMITTED
  PTO_APPROVED
  PTO_DENIED
  SHIFT_SWAP_REQUESTED
  SHIFT_SWAP_APPROVED
  SHIFT_SWAP_DENIED
  TIMESHEET_APPROVED
  TIMESHEET_REJECTED
  SHIFT_REMINDER
}

// ─── Time Tracking Models ───────────────────────────────────────

model Department {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  color          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
  @@index([organizationId])
}

model TimeEntry {
  id              String    @id @default(cuid())
  userId          String
  organizationId  String
  locationId      String?
  timesheetId     String?
  date            DateTime  @db.Date
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  regularHours    Float     @default(0)
  overtimeHours   Float     @default(0)
  breakMinutes    Int       @default(0)
  breakType       BreakType @default(UNPAID)
  payRateId       String?
  note            String?
  isClockIn       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  timesheet    Timesheet?   @relation(fields: [timesheetId], references: [id])
  payRate      PayRate?     @relation(fields: [payRateId], references: [id])

  @@index([userId, date])
  @@index([organizationId])
  @@index([timesheetId])
}

model Timesheet {
  id                 String          @id @default(cuid())
  userId             String
  organizationId     String
  payPeriodStart     DateTime        @db.Date
  payPeriodEnd       DateTime        @db.Date
  status             TimesheetStatus @default(DRAFT)
  totalRegularHours  Float           @default(0)
  totalOvertimeHours Float           @default(0)
  totalHours         Float           @default(0)
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewedById       String?
  rejectionNote      String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user         User                 @relation(fields: [userId], references: [id])
  organization Organization         @relation(fields: [organizationId], references: [id])
  entries      TimeEntry[]
  amendments   TimesheetAmendment[]

  @@unique([userId, payPeriodStart, payPeriodEnd])
  @@index([organizationId, status])
  @@index([userId])
}

model ShiftAssignment {
  id             String    @id @default(cuid())
  employeeId     String
  organizationId String
  locationId     String?
  date           DateTime  @db.Date
  startTime      String
  endTime        String
  roleLabel      String?
  hours          Float
  isPublished    Boolean   @default(false)
  reminderSentAt DateTime?
  payRateId      String?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  payRate      PayRate?     @relation(fields: [payRateId], references: [id])

  @@index([organizationId, date])
  @@index([employeeId, date])
  @@index([organizationId, isPublished])
  @@index([payRateId])
}

model AvailabilityPreference {
  id             String            @id @default(cuid())
  employeeId     String
  organizationId String
  dayOfWeek      DayOfWeek
  state          AvailabilityState
  startTime      String?
  endTime        String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([employeeId, dayOfWeek])
  @@index([organizationId])
}

model AvailabilityOverride {
  id             String   @id @default(cuid())
  employeeId     String
  organizationId String
  date           DateTime @db.Date
  unavailable    Boolean  @default(true)
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([employeeId, date])
  @@index([organizationId])
}

model PtoRequest {
  id             String    @id @default(cuid())
  employeeId     String
  organizationId String
  startDate      DateTime  @db.Date
  endDate        DateTime  @db.Date
  type           PtoType
  note           String?
  status         PtoStatus @default(PENDING)
  responseNote   String?
  reviewedById   String?
  submittedAt    DateTime  @default(now())
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, status])
  @@index([employeeId])
}

model ShiftSwapRequest {
  id               String          @id @default(cuid())
  organizationId   String
  requesterId      String
  requestedId      String
  requesterShiftId String
  requestedShiftId String?
  status           ShiftSwapStatus @default(PENDING)
  note             String?
  responseNote     String?
  reviewedById     String?
  requestedAt      DateTime        @default(now())
  reviewedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, status])
  @@index([requesterId])
  @@index([requestedId])
}

model ScheduleTemplate {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  shiftPattern   Json
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model CoverageRequirement {
  id             String    @id @default(cuid())
  organizationId String
  departmentId   String?
  dayOfWeek      DayOfWeek
  startTime      String
  endTime        String
  minEmployees   Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, dayOfWeek])
}

model PayRate {
  id             String    @id @default(cuid())
  userId         String
  organizationId String
  name           String
  ratePerHour    Decimal   @db.Decimal(10, 2)
  effectiveFrom  DateTime  @db.Date
  effectiveTo    DateTime? @db.Date
  isDefault      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  timeEntries      TimeEntry[]
  shiftAssignments ShiftAssignment[]

  @@index([userId, organizationId])
  @@index([organizationId])
}

model TimesheetAmendment {
  id          String   @id @default(cuid())
  timesheetId String
  timeEntryId String?
  fieldName   String
  oldValue    String
  newValue    String
  changedById String
  changedAt   DateTime @default(now())
  reason      String?

  timesheet Timesheet @relation(fields: [timesheetId], references: [id])

  @@index([timesheetId, changedAt])
  @@index([timeEntryId])
}

// ─── Notification Model ─────────────────────────────────────────

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  type           NotificationType
  title          String
  message        String
  entityType     String?
  entityId       String?
  read           Boolean          @default(false)
  emailSent      Boolean          @default(false)
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([organizationId, createdAt])
}

// ─── PharmShift Scheduling Models ──────────────────────────────

model WeeklySchedule {
  id             String    @id @default(cuid())
  organizationId String
  locationId     String
  weekStart      String    // ISO date YYYY-MM-DD (Monday)
  status         String    @default("Not Started") // "Not Started" | "In Progress" | "Finalized"
  lastUpdated    DateTime  @default(now())
  finalizedAt    DateTime?
  createdAt      DateTime  @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id])
  location     Location          @relation(fields: [locationId], references: [id])
  entries      ScheduleEntry[]
  comments     ScheduleComment[]

  @@unique([locationId, weekStart])
  @@index([organizationId])
  @@index([locationId])
}

model ScheduleEntry {
  id           String  @id @default(cuid())
  scheduleId   String
  employeeId   String
  employeeName String
  day          String  // "Monday", "Tuesday", etc.
  available    Boolean @default(true)
  startTime    String  @default("9:00 AM")
  endTime      String  @default("5:00 PM")
  role         String  @default("Filling")

  schedule WeeklySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, employeeId, day])
  @@index([scheduleId])
}

model ScheduleComment {
  id         String   @id @default(cuid())
  scheduleId String
  text       String
  createdAt  DateTime @default(now())

  schedule WeeklySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
}
